---
import T from "./T.astro";
import { site } from "../data/site";
const base = import.meta.env.BASE_URL;
const year = 2026;
---
<footer class="border-t border-white/8 bg-bg-1/50">
  <div class="mx-auto max-w-6xl px-5 py-14">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div>
        <div class="flex items-center gap-2.5">
          <img src={`${base}assets/img/logo-white.png`} alt="" width="28" height="28" class="size-7" />
          <span class="font-display text-lg font-semibold">Screen<span class="grad-text">Pencil</span></span>
        </div>
        <p class="mt-4 max-w-xs text-sm text-ink-soft">
          <T es="Dibuja sobre toda tu pantalla. Gratis y para todos." en="Draw over your entire screen. Free and for everyone." />
        </p>
      </div>

      <nav class="text-sm">
        <h4 class="font-display font-semibold text-ink"><T es="Producto" en="Product" /></h4>
        <ul class="mt-3 space-y-2 text-ink-soft">
          <li><a href="#features" class="transition hover:text-ink"><T es="Funciones" en="Features" /></a></li>
          <li><a href="#flow" class="transition hover:text-ink"><T es="Cómo funciona" en="How it works" /></a></li>
          <li><a href="#demo" class="transition hover:text-ink">Demo</a></li>
          <li><a href="#download" class="transition hover:text-ink"><T es="Descargar" en="Download" /></a></li>
        </ul>
      </nav>

      <nav class="text-sm">
        <h4 class="font-display font-semibold text-ink"><T es="Recursos" en="Resources" /></h4>
        <ul class="mt-3 space-y-2 text-ink-soft">
          <li><a href="#faq" class="transition hover:text-ink">FAQ</a></li>
          <li><a href={`${base}bug`} class="transition hover:text-ink"><T es="Reportar un bug" en="Report a bug" /></a></li>
          <li><a href="#donate" class="transition hover:text-ink"><T es="Donar / Apóyanos" en="Donate / Support" /></a></li>
          <li><a href={site.releasesRepo} target="_blank" rel="noopener" data-github class="transition hover:text-ink">GitHub</a></li>
        </ul>
      </nav>

      <nav class="text-sm">
        <h4 class="font-display font-semibold text-ink"><T es="Plataformas" en="Platforms" /></h4>
        <ul class="mt-3 space-y-2 text-ink-soft">
          <li>Windows 10/11</li>
          <li>macOS</li>
          <li class="opacity-70">Linux <T es="· experimental" en="· experimental" /></li>
          <li class="opacity-70">Android <T es="· pronto" en="· soon" /></li>
        </ul>
      </nav>
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-3 border-t border-white/8 pt-6 text-sm text-ink-dim sm:flex-row">
      <span>© {year} ScreenPencil · <T es="Hecho con 💜 por" en="Made with 💜 by" /> <a href="https://github.com/gepres" target="_blank" rel="noopener" class="text-ink-soft hover:text-ink">gepres</a></span>
      <span><T es="Licencia MIT · Software libre" en="MIT License · Free software" /></span>
    </div>
  </div>
</footer>
