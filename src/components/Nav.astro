---
import Icon from "./Icon.astro";
import T from "./T.astro";
import { site } from "../data/site";
const base = import.meta.env.BASE_URL;
---
<header
  data-nav
  class="fixed inset-x-0 top-0 z-50 border-b border-transparent bg-transparent transition-colors duration-300 data-[scrolled]:border-white/5 data-[scrolled]:bg-bg-0/55 data-[scrolled]:backdrop-blur-lg"
>
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-5">
    <a href="#top" class="flex items-center gap-2.5" aria-label="ScreenPencil — inicio">
      <img src={`${base}assets/img/logo-white.png`} alt="" width="28" height="28" class="size-7" />
      <span class="font-display text-lg font-semibold tracking-tight">Screen<span class="grad-text">Pencil</span></span>
    </a>

    <div class="hidden items-center gap-7 text-sm text-ink-soft md:flex">
      <a href="#features" class="transition hover:text-ink"><T es="Funciones" en="Features" /></a>
      <a href="#showcase" class="transition hover:text-ink"><T es="En acción" en="In action" /></a>
      <a href="#demo" class="transition hover:text-ink">Demo</a>
      <a href="#faq" class="transition hover:text-ink">FAQ</a>
    </div>

    <div class="flex items-center gap-2">
      <button
        data-lang-toggle
        class="rounded-full border border-white/10 px-3 py-1.5 text-xs font-semibold text-ink-soft transition hover:border-white/25 hover:text-ink"
        aria-label="Cambiar idioma / Switch language"
      >
        <span data-lang-label>EN</span>
      </button>
      <a
        href={site.releasesRepo}
        target="_blank"
        rel="noopener"
        data-github
        class="hidden size-9 place-items-center rounded-full border border-white/10 text-ink-soft transition hover:border-white/25 hover:text-ink sm:grid"
        aria-label="GitHub"
      >
        <Icon name="github" class="size-4" />
      </a>
      <a
        href="#download"
        aria-label="Descargar / Download"
        class="inline-flex items-center justify-center gap-1.5 rounded-full bg-ink p-2.5 text-sm font-semibold text-bg-0 transition hover:bg-white sm:px-4 sm:py-2"
      >
        <Icon name="download" class="size-4" />
        <span class="hidden sm:inline"><T es="Descargar" en="Download" /></span>
      </a>
      <button
        data-burger
        class="grid size-9 place-items-center rounded-full border border-white/10 text-ink-soft md:hidden"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <Icon name="menu" class="size-5" />
      </button>
    </div>
  </nav>

  <!-- Menú móvil (glass translúcido, como el nav) -->
  <div data-mobile-menu class="hidden flex-col gap-1 border-t border-white/5 bg-bg-0/60 px-5 py-3 text-sm text-ink-soft backdrop-blur-lg data-[open]:flex md:!hidden">
    <a href="#features" class="py-2"><T es="Funciones" en="Features" /></a>
    <a href="#showcase" class="py-2"><T es="En acción" en="In action" /></a>
    <a href="#demo" class="py-2">Demo</a>
    <a href="#faq" class="py-2">FAQ</a>
  </div>
</header>
