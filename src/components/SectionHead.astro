---
import T from "./T.astro";
interface Props {
  eyebrowEs: string;
  eyebrowEn: string;
  titleEs: string;
  titleEn: string;
  subEs?: string;
  subEn?: string;
  center?: boolean;
}
const { eyebrowEs, eyebrowEn, titleEs, titleEn, subEs, subEn, center = true } = Astro.props;
---
<div class={`reveal ${center ? "mx-auto max-w-2xl text-center" : "max-w-2xl"}`}>
  <span class="font-display text-sm font-semibold uppercase tracking-[0.18em] text-amber">
    <T es={eyebrowEs} en={eyebrowEn} />
  </span>
  <h2 class="mt-3 text-3xl font-bold sm:text-4xl">
    <T es={titleEs} en={titleEn} />
  </h2>
  {subEs && (
    <p class="mt-4 text-lg leading-relaxed text-ink-soft">
      <T es={subEs} en={subEn || subEs} />
    </p>
  )}
</div>
