---
import Base from "../layouts/Base.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import T from "../components/T.astro";
import { site } from "../data/site";
const base = import.meta.env.BASE_URL;
---
<Base
  title="Reportar un bug — ScreenPencil"
  titleEn="Report a bug — ScreenPencil"
  description="¿Encontraste un problema en ScreenPencil? Cuéntanoslo (puedes adjuntar una captura) y lo revisamos."
  descriptionEn="Found a problem in ScreenPencil? Tell us (you can attach a screenshot) and we'll look into it."
>
  <!-- Header mínimo (no el nav de anclas de la home) -->
  <header class="fixed inset-x-0 top-0 z-50 border-b border-white/8 bg-bg-0/85 backdrop-blur-md">
    <nav class="mx-auto flex h-16 max-w-3xl items-center justify-between gap-4 px-5">
      <a href={base} class="flex items-center gap-2.5" aria-label="ScreenPencil — inicio">
        <img src={`${base}assets/img/logo-white.png`} alt="" width="28" height="28" class="size-7" />
        <span class="font-display text-lg font-semibold tracking-tight">Screen<span class="grad-text">Pencil</span></span>
      </a>
      <div class="flex items-center gap-2">
        <button data-lang-toggle class="rounded-full border border-white/10 px-3 py-1.5 text-xs font-semibold text-ink-soft transition hover:border-white/25 hover:text-ink" aria-label="Cambiar idioma / Switch language">
          <span data-lang-label>EN</span>
        </button>
        <a href={base} class="inline-flex items-center gap-1.5 rounded-full border border-white/15 px-4 py-2 text-sm font-semibold text-ink transition hover:border-white/30 hover:bg-white/5">
          <T es="← Volver" en="← Back" />
        </a>
      </div>
    </nav>
  </header>

  <main class="mx-auto max-w-2xl px-5 pb-24 pt-28 md:pt-32">
    <div class="text-center">
      <span class="font-display text-sm font-semibold uppercase tracking-[0.18em] text-amber">
        <T es="Reportar un bug" en="Report a bug" />
      </span>
      <h1 class="mt-3 text-3xl font-bold sm:text-4xl">
        <T es="¿Algo no funciona como esperabas?" en="Something not working as expected?" />
      </h1>
      <p class="mx-auto mt-4 max-w-lg text-ink-soft">
        <T
          es="Cuéntanos qué pasó. Cuanto más detalle (y una captura), más rápido lo arreglamos. Te responderemos al correo que dejes."
          en="Tell us what happened. The more detail (and a screenshot), the faster we fix it. We'll reply to the email you provide."
        />
      </p>
    </div>

    <form data-bug-form class="mt-10 grid gap-5 rounded-3xl border border-white/8 bg-bg-1 p-6 sm:p-8">
      <!-- Honeypot anti-spam (oculto para humanos) -->
      <input type="text" name="_honey" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

      <div class="grid gap-5 sm:grid-cols-2">
        <label class="text-sm font-medium text-ink-soft">
          <T es="Tu correo" en="Your email" /> <span class="text-amber">*</span>
          <input name="email" type="email" required placeholder="tu@correo.com"
            class="mt-1.5 w-full rounded-xl border border-white/12 bg-bg-0 px-3.5 py-2.5 text-ink outline-none transition focus:border-amber/50" />
        </label>
        <label class="text-sm font-medium text-ink-soft">
          <T es="Tipo" en="Type" />
          <select name="type" class="mt-1.5 w-full rounded-xl border border-white/12 bg-bg-0 px-3.5 py-2.5 text-ink outline-none focus:border-amber/50">
            <option value="Bug">🐞 Bug</option>
            <option value="Sugerencia">💡 Sugerencia / Suggestion</option>
            <option value="Otro">💬 Otro / Other</option>
          </select>
        </label>
      </div>

      <label class="text-sm font-medium text-ink-soft">
        <T es="Resumen" en="Summary" /> <span class="text-amber">*</span>
        <input name="title" type="text" required maxlength="120"
          placeholder="Ej.: el spotlight no se ve en el segundo monitor"
          class="mt-1.5 w-full rounded-xl border border-white/12 bg-bg-0 px-3.5 py-2.5 text-ink outline-none transition focus:border-amber/50" />
      </label>

      <label class="text-sm font-medium text-ink-soft">
        <T es="¿Qué pasó?" en="What happened?" /> <span class="text-amber">*</span>
        <textarea name="description" required rows="4"
          placeholder="Describe el problema con el mayor detalle posible…"
          class="mt-1.5 w-full resize-y rounded-xl border border-white/12 bg-bg-0 px-3.5 py-2.5 text-ink outline-none transition focus:border-amber/50"></textarea>
      </label>

      <label class="text-sm font-medium text-ink-soft">
        <T es="Pasos para reproducirlo" en="Steps to reproduce" /> <span class="text-ink-dim">(<T es="opcional" en="optional" />)</span>
        <textarea name="steps" rows="3"
          placeholder="1) … 2) … 3) …"
          class="mt-1.5 w-full resize-y rounded-xl border border-white/12 bg-bg-0 px-3.5 py-2.5 text-ink outline-none transition focus:border-amber/50"></textarea>
      </label>

      <div class="grid gap-5 sm:grid-cols-2">
        <label class="text-sm font-medium text-ink-soft">
          <T es="Sistema" en="Platform" />
          <select name="platform" class="mt-1.5 w-full rounded-xl border border-white/12 bg-bg-0 px-3.5 py-2.5 text-ink outline-none focus:border-amber/50">
            <option value="Windows">Windows</option>
            <option value="macOS">macOS</option>
            <option value="Linux">Linux</option>
            <option value="Otro">Otro / Other</option>
          </select>
        </label>
        <label class="text-sm font-medium text-ink-soft">
          <T es="Versión de la app" en="App version" />
          <input name="version" type="text" value={site.version}
            class="mt-1.5 w-full rounded-xl border border-white/12 bg-bg-0 px-3.5 py-2.5 text-ink outline-none transition focus:border-amber/50" />
        </label>
      </div>

      <label class="text-sm font-medium text-ink-soft">
        <T es="Captura de pantalla" en="Screenshot" /> <span class="text-ink-dim">(<T es="opcional · máx 2 MB" en="optional · max 2 MB" />)</span>
        <input name="bug_image" type="file" accept="image/*"
          class="mt-1.5 w-full cursor-pointer rounded-xl border border-white/12 bg-bg-0 px-3.5 py-2.5 text-sm text-ink-soft file:mr-3 file:rounded-lg file:border-0 file:bg-white/10 file:px-3 file:py-1.5 file:text-ink hover:file:bg-white/15" />
      </label>

      <!-- Campos automáticos -->
      <input type="hidden" name="from_name" />
      <input type="hidden" name="reply_to" />
      <input type="hidden" name="subject" />
      <input type="hidden" name="browser" />
      <input type="hidden" name="page" />
      <input type="hidden" name="message" />

      <div class="flex flex-wrap items-center gap-4">
        <button data-bug-submit type="submit"
          class="inline-flex items-center gap-2 rounded-full bg-amber px-6 py-3 font-semibold text-bg-0 transition hover:bg-amber/90 disabled:cursor-not-allowed disabled:opacity-60">
          <Icon name="arrow" class="size-4" />
          <span data-bug-btn-label><T es="Enviar reporte" en="Send report" /></span>
        </button>
        <p class="text-xs text-ink-dim">
          <T es="También puedes abrir un issue en" en="You can also open an issue on" />
          <a href={`${site.releasesRepo}/issues`} target="_blank" rel="noopener" class="text-ink-soft underline underline-offset-2 hover:text-ink">GitHub</a>.
        </p>
      </div>

      <div data-bug-status class="hidden rounded-xl border px-4 py-3 text-sm" role="status"></div>
    </form>
  </main>

  <Footer />

  <script>
    import "../scripts/bug.ts";
  </script>
</Base>
